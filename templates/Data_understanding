            <td><div class="corr-cell" style="background:rgba(138,99,210,.05);color:var(--muted);">0.034</div></td>
          </tr>
          <tr>
            <th style="text-align:left;font-family:'DM Mono',monospace;font-size:.62rem;color:var(--muted);">PM10</th>
            <td><div class="corr-cell" style="background:rgba(138,99,210,.05);color:var(--muted);">-0.018</div></td>
            <td><div class="corr-cell" style="background:rgba(138,99,210,.3);color:var(--text);">0.206</div></td>
            <td><div class="corr-cell" style="background:rgba(138,99,210,.07);color:var(--muted);">0.044</div></td>
