            <td><div class="corr-cell" style="background:rgba(138,99,210,.05);color:var(--muted);">-0.016</div></td>
          </tr>
          <tr>
            <th style="text-align:left;font-family:'DM Mono',monospace;font-size:.62rem;color:var(--muted);">Dist. Vía</th>
            <td><div class="corr-cell" style="background:rgba(138,99,210,.05);color:var(--muted);">-0.054</div></td>
            <td><div class="corr-cell" style="background:rgba(138,99,210,.05);color:var(--muted);">0.040</div></td>
